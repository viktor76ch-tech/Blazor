@page "/students/details"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@inject IDbContextFactory<BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Student Details</PageTitle>

<h1>Student Details</h1>

<div>
    <hr />
    @if (student is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-3">Last Name</dt>
            <dd class="col-sm-9">@student.LastName</dd>
            
            <dt class="col-sm-3">First Name</dt>
            <dd class="col-sm-9">@student.FirstName</dd>
            
            <dt class="col-sm-3">Middle Name</dt>
            <dd class="col-sm-9">@student.MiddleName</dd>
            
            <dt class="col-sm-3">Birth Date</dt>
            <dd class="col-sm-9">@student.BirthDate.ToString("dd.MM.yyyy")</dd>
            
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@(student.Email ?? "—")</dd>
            
            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@(student.Phone ?? "—")</dd>
            
            <dt class="col-sm-3">Group</dt>
            <dd class="col-sm-9">@(student.GroupNm?.GroupName ?? "No group")</dd>
            
            <dt class="col-sm-3">Photo</dt>
            <dd class="col-sm-9">
                @if (student.Photo != null && student.Photo.Length > 0)
                {
                    <img src="data:image/png;base64,@Convert.ToBase64String(student.Photo)"
                         alt="Student photo" style="max-width: 300px;" class="img-thumbnail" />
                }
                else
                {
                    <span>No photo</span>
                }
            </dd>
        </dl>
        <div class="mt-3">
            <a href="@($"/students/edit?studid={student.StudId}")" class="btn btn-primary">Edit</a>
            <a href="/students" class="btn btn-secondary ms-2">Back to List</a>
        </div>
    }
</div>

@code {
    private Students? student;

    [SupplyParameterFromQuery]
    private int StudId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        // Загружаем студента вместе с информацией о группе
        student = await context.Students
            .Include(s => s.GroupNm)
            .FirstOrDefaultAsync(m => m.StudId == StudId);

        if (student is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}