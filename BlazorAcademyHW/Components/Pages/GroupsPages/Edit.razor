@page "/groups/edit"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@inject IDbContextFactory<BlazorAcademyHWContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Edit Group</PageTitle>

<h1>Edit Group</h1>

<hr />

@if (editGroup == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <EditForm Model="editGroup" OnValidSubmit="HandleValidSubmit" FormName="edit-group">
                <DataAnnotationsValidator />
                <ValidationSummary />
                
                <div class="mb-3">
                    <label class="form-label">Group Name:</label>
                    <InputText class="form-control" @bind-Value="editGroup.GroupName" />
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Direction:</label>
                    <InputSelect class="form-control" @bind-Value="editGroup.Direction">
                        <option value="">Select Direction</option>
                        @if (directions != null)
                        {
                            @foreach (var dir in directions)
                            {
                                <option value="@dir.DirectionId">@dir.DirectionName</option>
                            }
                        }
                    </InputSelect>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Schedule Days:</label>
                    <div class="row">
                        @foreach (var day in availableDays)
                        {
                            <div class="col-auto">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input"
                                           id="edit_day_@day.Value"
                                           checked="@selectedDays.Contains(day.Value)"
                                           @onchange="e => ToggleDay(day.Value, (bool)e.Value!)" />
                                    <label class="form-check-label" for="edit_day_@day.Value">@day.Key</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                
                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a href="/groups" class="btn btn-secondary ms-2">Cancel</a>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    public int GroupId { get; set; }
    
    private Groups? editGroup;
    private List<Directions>? directions;
    private HashSet<byte> selectedDays = new();

    private Dictionary<string, byte> availableDays = new()
    {
        {"Понедельник", 1},
        {"Вторник", 2},
        {"Среда", 3},
        {"Четверг", 4},
        {"Пятница", 5},
        {"Суббота", 6},
        {"Воскресенье", 0}
    };

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        directions = await context.Directions.ToListAsync();
        
        editGroup = await context.Groups
            .Include(g => g.ScheduleDays)
            .FirstOrDefaultAsync(g => g.GroupId == GroupId);
            
        if (editGroup?.ScheduleDays != null)
        {
            selectedDays = new HashSet<byte>(editGroup.ScheduleDays.Select(s => s.DayOfWeek));
        }
    }

    private void ToggleDay(byte dayValue, bool isChecked)
    {
        if (isChecked)
            selectedDays.Add(dayValue);
        else
            selectedDays.Remove(dayValue);
    }

    private async Task HandleValidSubmit()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        var groupInDb = await context.Groups
            .Include(g => g.ScheduleDays)
            .FirstAsync(g => g.GroupId == GroupId);
            
        groupInDb.GroupName = editGroup!.GroupName;
        groupInDb.Direction = editGroup.Direction;
        
        // Удаляем старые дни расписания
        if (groupInDb.ScheduleDays != null && groupInDb.ScheduleDays.Any())
        {
            context.GroupScheduleDays.RemoveRange(groupInDb.ScheduleDays);
        }
        
        // Добавляем новые дни расписания
        groupInDb.ScheduleDays = selectedDays.Select(d => new GroupScheduleDays
        {
            GroupId = GroupId,
            DayOfWeek = d
        }).ToList();
        
        await context.SaveChangesAsync();
        Navigation.NavigateTo("/groups");
    }
}