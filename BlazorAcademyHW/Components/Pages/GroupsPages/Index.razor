@page "/groups"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@implements IAsyncDisposable
@inject IDbContextFactory<BlazorAcademyHWContext> DbFactory

<PageTitle>Groups</PageTitle>

<h1>Groups</h1>

<p>
    <a href="groups/create">Create New</a>
</p>

<div class="col-md-4">
    <label class="form-label">Filter by Direction:</label>
    <select class="form-select" @bind="selectedDirectionId" @bind:after="ApplyFilter">
        <option value="">All Direction</option>
        @if (directions != null)
        {
            @foreach (var direction in directions)
            {
                <option value="@direction.DirectionId">@direction.DirectionName</option>
            }
        }
    </select>
</div>

@if (groupsQuery != null)
{
    <div>
        <QuickGrid Class="table" Items="groupsQuery" Pagination="pagination">
            <PropertyColumn Property="g => g.GroupName" Sortable="true" />
            <PropertyColumn Property="g => g.DirectionNM.DirectionName" Sortable="true" />

            <TemplateColumn Title="Schedule" Sortable="false">
                @GetScheduleString(context)
            </TemplateColumn>

            <TemplateColumn Context="group">
                <a href="@($"groups/edit?groupid={group.GroupId}")">Edit</a> |
                <a href="@($"groups/details?groupid={group.GroupId}")">Details</a> |
                <a href="@($"groups/delete?groupid={group.GroupId}")">Delete</a>
            </TemplateColumn>
        </QuickGrid>
    </div>
    <Paginator State="pagination" />
}
else
{
    <div class="alert alert-info">
        <em>Loading...</em>
    </div>
}

@code {
    private BlazorAcademyHWContext context = default!;
    private IQueryable<Groups>? groupsQuery;
    private List<Directions>? directions;
    private PaginationState pagination = new() { ItemsPerPage = 3 };

    private byte? selectedDirectionId = null;

    protected override async Task OnInitializedAsync()
    {
        context = await DbFactory.CreateDbContextAsync();
        directions = await context.Directions.ToListAsync();
        
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        var query = context.Groups
            .Include(g => g.DirectionNM)
            .Include(g => g.ScheduleDays)
            .AsQueryable();
        
        if (selectedDirectionId.HasValue)
        {
            query = query.Where(g => g.Direction == selectedDirectionId.Value);
        }
        
        groupsQuery = query;
    }

    private string GetScheduleString(Groups group)
    {
        if (group.ScheduleDays == null || !group.ScheduleDays.Any()) return "—";
        
        var dayNames = group.ScheduleDays
            .OrderBy(d => d.DayOfWeek)
            .Select(d => d.DayOfWeek switch
            {
                0 => "Вс",
                1 => "Пн",
                2 => "Вт",
                3 => "Ср",
                4 => "Чт",
                5 => "Пт",
                6 => "Сб",
                _ => "???"
            });
        
        return string.Join(", ", dayNames);
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}