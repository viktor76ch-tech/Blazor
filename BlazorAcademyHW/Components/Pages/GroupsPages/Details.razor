@page "/groups/details"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@inject IDbContextFactory<BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Group Details</PageTitle>

<h1>Group Details</h1>

<div>
    <hr />
    @if (group is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-3">Group Name</dt>
            <dd class="col-sm-9">@group.GroupName</dd>
            
            <dt class="col-sm-3">Direction</dt>
            <dd class="col-sm-9">@(group.DirectionNM?.DirectionName ?? "No direction")</dd>
            
            <dt class="col-sm-3">Schedule</dt>
            <dd class="col-sm-9">
                @if (group.ScheduleDays != null && group.ScheduleDays.Any())
                {
                    var days = group.ScheduleDays.OrderBy(d => d.DayOfWeek).Select(d => d.DayOfWeek switch
                    {
                        0 => "Воскресенье",
                        1 => "Понедельник",
                        2 => "Вторник",
                        3 => "Среда",
                        4 => "Четверг",
                        5 => "Пятница",
                        6 => "Суббота",
                        _ => "Неизвестный"
                    });
                    @string.Join(", ", days)
                }
                else
                {
                    @:No schedule days set
                }
            </dd>
        </dl>
        <div class="mt-3">
            <a href="@($"/groups/edit?groupid={group.GroupId}")" class="btn btn-primary">Edit</a>
            <a href="/groups" class="btn btn-secondary ms-2">Back to List</a>
        </div>
    }
</div>

@code {
    private Groups? group;

    [SupplyParameterFromQuery]
    private int GroupId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        group = await context.Groups
            .Include(g => g.DirectionNM)
            .Include(g => g.ScheduleDays)
            .FirstOrDefaultAsync(m => m.GroupId == GroupId);

        if (group is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}