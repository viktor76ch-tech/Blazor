@page "/directions/delete"
@inject BlazorAcademyHW.Data.BlazorAcademyHWContext DB
@using BlazorAcademyHW.Models
@inject NavigationManager NavigationManager
@using Microsoft.EntityFrameworkCore

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Direction</h4>
    <hr />
    @if (direction is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">DirectionName</dt>
            <dd class="col-sm-10">@direction.DirectionName</dd>
        </dl>
        <EditForm method="post" Model="direction" OnValidSubmit="DeleteDirection" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(direction is null)">Delete</button> |
            <a href="/directions">Back to List</a>
        </EditForm>
    }
</div>

@code {
    Direction? direction;

    [SupplyParameterFromQuery]
    public byte DirectionId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        direction = await DB.Direction.FirstOrDefaultAsync(m => m.DirectionId == DirectionId);

        if (direction is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    public async Task DeleteDirection()
    {
        DB.Direction.Remove(direction!);
        await DB.SaveChangesAsync();
        NavigationManager.NavigateTo("/directions");
    }
}
