@page "/teachers/edit"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@inject IDbContextFactory<BlazorAcademyHWContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Edit Teacher</PageTitle>

<h1>Edit Teacher</h1>

<hr />

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else if (teacher == null)
{
    <div class="alert alert-warning">
        <p>Teacher not found.</p>
        <a href="/teachers">Back to List</a>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Last Name:</label>
                <InputText class="form-control" @bind-Value="lastName" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">First Name:</label>
                <InputText class="form-control" @bind-Value="firstName" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Middle Name:</label>
                <InputText class="form-control" @bind-Value="middleName" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Birth Date:</label>
                <InputDate class="form-control" @bind-Value="birthDate" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Email:</label>
                <InputText class="form-control" @bind-Value="email" type="email" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Phone:</label>
                <InputText class="form-control" @bind-Value="phone" type="tel" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Work Since:</label>
                <InputDate class="form-control" @bind-Value="workSince" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Rate:</label>
                <InputNumber class="form-control" @bind-Value="rate" />
            </div>
            
            <div class="mb-3">
                <button class="btn btn-primary" @onclick="UpdateTeacher">Save</button>
                <a href="/teachers" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "teacherid")]
    public int TeacherId { get; set; }
    
    private Teachers? teacher;
    private bool isLoading = true;
    
    private string? lastName;
    private string? firstName;
    private string? middleName;
    private DateOnly? birthDate;
    private string? email;
    private string? phone;
    private DateOnly? workSince;
    private decimal? rate;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        teacher = await context.Teachers
            .AsNoTracking()
            .FirstOrDefaultAsync(t => t.TeacherId == (short)TeacherId);
            
        if (teacher != null)
        {
            lastName = teacher.LastName;
            firstName = teacher.FirstName;
            middleName = teacher.MiddleName;
            birthDate = teacher.BirthDate;
            email = teacher.Email;
            phone = teacher.Phone;
            workSince = teacher.WorkSince;
            rate = teacher.Rate;
        }
        
        isLoading = false;
    }

    private async Task UpdateTeacher()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        var teacherInDb = await context.Teachers.FindAsync((short)TeacherId);
        
        if (teacherInDb != null)
        {
            teacherInDb.LastName = lastName;
            teacherInDb.FirstName = firstName;
            teacherInDb.MiddleName = middleName;
            teacherInDb.BirthDate = birthDate;
            teacherInDb.Email = email;
            teacherInDb.Phone = phone;
            teacherInDb.WorkSince = workSince;
            teacherInDb.Rate = rate;
            
            await context.SaveChangesAsync();
        }
        
        Navigation.NavigateTo("/teachers");
    }
}