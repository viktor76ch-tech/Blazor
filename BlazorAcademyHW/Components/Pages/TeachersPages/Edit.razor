@page "/teachers/edit"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@inject IDbContextFactory<BlazorAcademyHWContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Edit Teacher</PageTitle>

<h1>Edit Teacher</h1>

<hr />

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else if (teacher == null)
{
    <div class="alert alert-warning">
        <p>Teacher not found.</p>
        <a href="/teachers">Back to List</a>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Last Name:</label>
                <InputText class="form-control" @bind-Value="lastName" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">First Name:</label>
                <InputText class="form-control" @bind-Value="firstName" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Middle Name:</label>
                <InputText class="form-control" @bind-Value="middleName" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Birth Date:</label>
                <InputDate class="form-control" @bind-Value="birthDate" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Email:</label>
                <InputText class="form-control" @bind-Value="email" type="email" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Phone:</label>
                <InputText class="form-control" @bind-Value="phone" type="tel" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Work Since:</label>
                <InputDate class="form-control" @bind-Value="workSince" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Rate:</label>
                <InputNumber class="form-control" @bind-Value="rate" />
            </div>
            
            <!-- ДОБАВЛЕНО: текущее фото -->
            <div class="mb-3">
                <label class="form-label">Current Photo:</label>
                @if (currentPhoto != null)
                {
                    <div class="mb-2">
                        <img src="data:image/png;base64,@Convert.ToBase64String(currentPhoto)"
                             alt="Current photo" style="max-width: 200px;" />
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="removePhoto" @bind="removePhoto" />
                        <label class="form-check-label" for="removePhoto">Remove current photo</label>
                    </div>
                }
                else
                {
                    <p>No photo</p>
                }
            </div>
            
            <!-- ДОБАВЛЕНО: новое фото -->
            <div class="mb-3">
                <label class="form-label">New Photo:</label>
                <InputFile OnChange="OnInputFileChange" accept="image/*" />
                @if (previewUrl != null)
                {
                    <div class="mt-2">
                        <p>New photo preview:</p>
                        <img src="@previewUrl" alt="Preview" style="max-width: 200px;" />
                    </div>
                }
            </div>
            
            <div class="mb-3">
                <button class="btn btn-primary" @onclick="UpdateTeacher">Save</button>
                <a href="/teachers" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "teacherid")]
    public int TeacherId { get; set; }
    
    private Teachers? teacher;
    private bool isLoading = true;
    
    private string? lastName;
    private string? firstName;
    private string? middleName;
    private DateOnly? birthDate;
    private string? email;
    private string? phone;
    private DateOnly? workSince;
    private decimal? rate;
    private byte[]? currentPhoto;
    private byte[]? newPhoto;
    private string? previewUrl;
    private bool removePhoto = false;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        teacher = await context.Teachers
            .AsNoTracking()
            .FirstOrDefaultAsync(t => t.TeacherId == (short)TeacherId);
            
        if (teacher != null)
        {
            lastName = teacher.LastName;
            firstName = teacher.FirstName;
            middleName = teacher.MiddleName;
            birthDate = teacher.BirthDate;
            email = teacher.Email;
            phone = teacher.Phone;
            workSince = teacher.WorkSince;
            rate = teacher.Rate;
            currentPhoto = teacher.Photo;
        }
        
        isLoading = false;
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        var buffer = new byte[file.Size];
        await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buffer);
        newPhoto = buffer;
        previewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
    }

    private async Task UpdateTeacher()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        var teacherInDb = await context.Teachers.FindAsync((short)TeacherId);
        
        if (teacherInDb != null)
        {
            teacherInDb.LastName = lastName;
            teacherInDb.FirstName = firstName;
            teacherInDb.MiddleName = middleName;
            teacherInDb.BirthDate = birthDate;
            teacherInDb.Email = email;
            teacherInDb.Phone = phone;
            teacherInDb.WorkSince = workSince;
            teacherInDb.Rate = rate;
            
            // ДОБАВЛЕНО: обработка фото
            if (removePhoto)
            {
                teacherInDb.Photo = null;
            }
            else if (newPhoto != null)
            {
                teacherInDb.Photo = newPhoto;
            }
            
            await context.SaveChangesAsync();
        }
        
        Navigation.NavigateTo("/teachers");
    }
}